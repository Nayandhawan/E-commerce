# Copy this file to .env and fill in real values. Never commit .env to git.

# ─── Database ───────────────────────────────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=change_me_strong_password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex_secret

# ─── Razorpay ────────────────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) for development
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ─── App ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:4200
