# ─── Dev Dockerfile: skips Angular build — use pre-built local dist ──────────
# 1. Build Angular locally first:
#    cd EcomUI && npm run build -- --configuration production --output-path dist/out
# 2. Then run:
#    docker compose -f docker-compose.dev.yml up --build

# ─── Stage 1: Build Spring Boot ──────────────────────────────────────────────
FROM eclipse-temurin:17-jdk-jammy AS app-builder
WORKDIR /app

COPY mvnw pom.xml ./
COPY .mvn .mvn
RUN ./mvnw dependency:go-offline -q

COPY src ./src

RUN rm -rf ./src/main/resources/static
RUN mkdir -p ./src/main/resources/static
COPY EcomUI/dist/out/browser ./src/main/resources/static

RUN ./mvnw package -DskipTests -q

# ─── Stage 2: Runtime ────────────────────────────────────────────────────────
FROM eclipse-temurin:17-jre-jammy
WORKDIR /app

RUN groupadd -r appgroup && useradd -r -g appgroup appuser
USER appuser

COPY --from=app-builder /app/target/ecom-0.0.1-SNAPSHOT.jar app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]
